				{
					"name": "Refresh the token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    let jsonData = pm.response.json();",
									"",
									"    if (jsonData.access_token) {",
									"        pm.collectionVariables.set(\"access_token\", jsonData.access_token);",
									"        console.log(\"✅ access_token saved to collection variables\");",
									"    } else {",
									"        console.warn(\"⚠️ access_token not found in response\");",
									"    }",
									"",
									"    if (jsonData.refresh_token) {",
									"        pm.collectionVariables.set(\"refresh_token\", jsonData.refresh_token);",
									"        console.log(\"✅ refresh_token saved to collection variables\");",
									"    } else {",
									"        console.warn(\"⚠️ refresh_token not found in response\");",
									"    }",
									"",
									"} else {",
									"    console.error(`❌ Token request failed with status ${pm.response.code}`);",
