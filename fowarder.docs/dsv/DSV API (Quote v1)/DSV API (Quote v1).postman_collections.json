{
	"info": {
		"_postman_id": "3d7f6613-c42e-4c8b-bc96-1a1f98b0052a",
		"name": "DSV API (Quote v1)",
		"description": "This collection provides all the necessary endpoints for integrating with DSV’s Quote API services.\n\n  \nIt includes:\n\n- **Authentication**: Fetch and refresh access tokens\n    \n- **Quote APIs**: Submit, retrieve, filter, and cancel quote requests\n    \n- **Webhooks**: Receive real-time notifications on quote lifecycle events\n    \n\nDesigned to support seamless and automated quoting workflows for shipment management across DSV’s supported transport modes.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "28876089"
	},
	"item": [
		{
			"name": "Fetch the Access Token",
			"item": [
				{
					"name": "Get the token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    let jsonData = pm.response.json();",
									"",
									"    if (jsonData.access_token) {",
									"        pm.collectionVariables.set(\"access_token\", jsonData.access_token);",
									"        console.log(\"✅ access_token saved to collection variables\");",
									"    } else {",
									"        console.warn(\"⚠️ access_token not found in response\");",
									"    }",
									"",
									"    if (jsonData.refresh_token) {",
									"        pm.collectionVariables.set(\"refresh_token\", jsonData.refresh_token);",
									"        console.log(\"✅ refresh_token saved to collection variables\");",
									"    } else {",
									"        console.warn(\"⚠️ refresh_token not found in response\");",
									"    }",
									"",
									"} else {",
									"    console.error(`❌ Token request failed with status ${pm.response.code}`);",
									"}",
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "apikey",
							"apikey": [
								{
									"key": "value",
									"value": "**Type your key**",
									"type": "string"
								},
								{
									"key": "key",
									"value": "DSV-Subscription-Key",
									"type": "string"
								}
							]
						},
