					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{access_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "DSV-Subscription-Key",
								"value": "**Type your key**",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"countryCode\": \"\",\r\n    \"transportMode\": \"\",\r\n    \"mdm\": \"\",\r\n    \"invoiceStartDateFilter\": \"2023-10-17\",\r\n    \"invoiceEndDateFilter\": \"\",\r\n    \"invoiceDueDateStartFilter\": \"\",\r\n    \"invoiceDueDateEndFilter\": \"\",\r\n    \"pageSize\": \"10\"\r\n}",
