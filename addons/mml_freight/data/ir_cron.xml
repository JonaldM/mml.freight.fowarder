<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_freight_tracking_sync" model="ir.cron">
        <field name="name">Freight: Sync Tracking Events</field>
        <field name="model_id" ref="model_freight_booking"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_tracking()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
    <record id="cron_freight_tender_expiry" model="ir.cron">
        <field name="name">Freight: Expire Overdue Quotes and Tenders</field>
        <field name="model_id" ref="model_freight_tender"/>
        <field name="state">code</field>
        <field name="code">model.cron_expire_tenders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active">True</field>
    </record>
    <record id="cron_contract_pace_alert" model="ir.cron">
        <field name="name">Freight: Contract Commitment Pace Alert</field>
        <field name="model_id" ref="model_freight_carrier_contract"/>
        <field name="state">code</field>
        <field name="code">model.cron_contract_pace_alert()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active">True</field>
    </record>
</odoo>
