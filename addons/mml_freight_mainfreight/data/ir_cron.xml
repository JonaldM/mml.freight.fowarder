<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Mainfreight A&O: dedicated tracking poll cron.

        NOTE: The generic cron_sync_tracking in mml_freight (interval: 30 min) already
        covers ALL carriers including Mainfreight — once mml_freight_mainfreight is
        installed and the 'mainfreight' adapter is registered, that cron processes
        Mainfreight bookings automatically.

        This dedicated cron is provided for installations that want a DIFFERENT
        polling interval for Mainfreight A&O specifically (e.g. less frequent due
        to API rate limits, or more frequent for high-priority shipments).

        By default this cron is INACTIVE — enable it only if you want to override
        the generic cron's interval for Mainfreight bookings specifically.

        IMPORTANT: Do NOT run both this cron AND the generic cron_sync_tracking
        simultaneously for the same carrier — it will cause duplicate API calls.
        If activating this cron, either disable the generic one or configure the
        generic one to skip 'mainfreight' delivery_type.
    -->
    <record id="cron_mf_tracking_poll" model="ir.cron">
        <field name="name">Freight Mainfreight: Poll A&amp;O Tracking</field>
        <field name="model_id" ref="delivery.model_delivery_carrier"/>
        <field name="state">code</field>
        <field name="code">model.cron_mf_tracking_poll()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="False"/>
    </record>
</odoo>
